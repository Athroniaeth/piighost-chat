# piighost-chat configuration
# Copy to .env and adjust values as needed:
#   cp .env.example .env

# ── LLM (OpenAI) ──────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-5.4-mini

# ── PIIGhost API ───────────────────────────────────────
# Leave empty to disable auth on piighost-api
PIIGHOST_API_KEY=
SECRET_PEPPER=

# ── Ports ──────────────────────────────────────────────
FRONTEND_PORT=5173
BACKEND_PORT=8001
POSTGRES_PORT=5432

# ── Thread cleanup worker ─────────────────────────────
# Max age (hours) before a thread is deleted by the hourly worker.
THREAD_TTL_HOURS=1
# If true, the worker logs stale threads but does not delete them.
CLEANUP_DRY_RUN=false
