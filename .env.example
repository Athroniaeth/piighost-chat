# piighost-chat configuration
# Copy to .env and adjust values as needed:
#   cp .env.example .env

# ── LLM (via LiteLLM) ─────────────────────────────────
# LLM_MODEL uses LiteLLM's "provider/model" syntax, e.g.:
#   openai/gpt-5.4-mini
#   anthropic/claude-3-5-sonnet-20241022
#   ollama/llama3
# The matching *_API_KEY env var is picked up automatically by LiteLLM.
OPENAI_API_KEY=sk-...
LLM_MODEL=openai/gpt-5.4-mini

# ── PIIGhost API ───────────────────────────────────────
# Leave empty to disable auth on piighost-api
PIIGHOST_API_KEY=
SECRET_PEPPER=

# ── Ports ──────────────────────────────────────────────
FRONTEND_PORT=5173
BACKEND_PORT=8001
POSTGRES_PORT=5432

# ── Thread cleanup worker ─────────────────────────────
# Max age (seconds) before a thread is deleted by the hourly worker.
THREAD_TTL_SECONDS=3600
# If true, the worker logs stale threads but does not delete them.
CLEANUP_DRY_RUN=false
