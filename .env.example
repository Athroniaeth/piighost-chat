# piighost-chat configuration
# Copy to .env and adjust values as needed:
#   cp .env.example .env

# ── LLM (via LiteLLM) ─────────────────────────────────
# LLM_MODEL uses LiteLLM's "provider/model" syntax, e.g.:
#   openai/gpt-5.4-mini
#   anthropic/claude-3-5-sonnet-20241022
#   ollama/llama3
LLM_MODEL=openai/gpt-5.4-mini

# Option A — call the provider directly: set the matching *_API_KEY below.
# LiteLLM reads OPENAI_API_KEY, ANTHROPIC_API_KEY, etc. automatically.
OPENAI_API_KEY=sk-...

# Option B — call a LiteLLM proxy or any OpenAI-compatible gateway.
# LLM_API_BASE overrides the provider URL; LLM_API_KEY overrides the
# credential. Leave empty to fall back to Option A.
# LLM_API_BASE=https://litellm.my-domain.com
# LLM_API_KEY=sk-proxy-...

# ── PIIGhost API ───────────────────────────────────────
# Leave empty to disable auth on piighost-api
PIIGHOST_API_KEY=
SECRET_PEPPER=

# ── Ports ──────────────────────────────────────────────
FRONTEND_PORT=5173
BACKEND_PORT=8001
POSTGRES_PORT=5432

# ── Thread cleanup worker ─────────────────────────────
# Max age (seconds) before a thread is deleted by the hourly worker.
THREAD_TTL_SECONDS=3600
# If true, the worker logs stale threads but does not delete them.
CLEANUP_DRY_RUN=false
